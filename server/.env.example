# ── ANTHROPIC ──────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
# Used for: outfit generation (claude-sonnet-4-6), follow-up questions (claude-haiku-4-5)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PERPLEXITY ─────────────────────────────────────────────────────────────
# Get from: https://perplexity.ai/settings/api
# Used for: product search (sonar), trend research (sonar-pro), brand research (sonar)
PERPLEXITY_API_KEY=pplx-your-key-here

# ── FASHN ──────────────────────────────────────────────────────────────────
# Get from: https://fashn.ai/dashboard
# Used for: virtual try-on (tryon-v1.6)
# Leave empty to show "Coming Soon" — no errors will occur
FASHN_API_KEY=your-fashn-key-here

# ── SERVER ─────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
